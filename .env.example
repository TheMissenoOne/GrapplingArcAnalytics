# Kaggle API — required for dataset download
# Get your API key at: https://www.kaggle.com/settings -> API -> Create New Token
KAGGLE_USERNAME=your_kaggle_username
KAGGLE_KEY=your_kaggle_api_key

# Roboflow API — optional, for BJJ3 dataset exploration
ROBOFLOW_API_KEY=your_roboflow_api_key

# ViCoS dataset download URL (stable)
VICOS_DOWNLOAD_BASE=https://vicos.si/resources/jiujitsu/

# Logging
LOG_LEVEL=INFO
